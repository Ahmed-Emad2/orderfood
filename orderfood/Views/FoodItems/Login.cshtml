@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول - نظام إدارة المطاعم</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background-color: #fff8f0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.1);
            background-color: #ffffff;
            max-width: 420px;
            width: 100%;
        }

        .login-header {
            background-color: #e52d3d;
            color: white;
            border-top-left-radius: 15px;
            border-top-right-radius: 15px;
            padding: 25px;
            text-align: center;
        }

        .btn-login {
            background-color: #ff9800;
            color: white;
            font-weight: bold;
            transition: all 0.3s ease;
            border: none;
        }

            .btn-login:hover {
                background-color: #e68a00;
                color: white;
                transform: translateY(-2px);
            }

        .form-control, .form-select {
            border-color: #ced4da;
        }

            .form-control:focus, .form-select:focus {
                border-color: #ff9800;
                box-shadow: 0 0 0 0.25rem rgba(255, 152, 0, 0.25);
            }
    </style>
</head>
<body>

    <div class="login-card shadow">
        <div class="login-header">
            <h3 class="fw-bold m-0"><i class="fa-solid fa-right-to-bracket mb-2"></i> بوابة تسجيل الدخول</h3>
            <p class="m-0 small">نظام إدارة المطاعم المتعددة</p>
        </div>

        <div class="card-body p-4" style="text-align: right;">

            @if (ViewData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger text-center fw-bold small p-2 mb-3" style="border-radius: 8px;">
                    @ViewData["ErrorMessage"]
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold text-dark"><i class="fa-solid fa-user text-muted me-1"></i> اسم المستخدم</label>
                    <input type="text" name="username" class="form-control" placeholder="اكتب اسم المستخدم هنا..." required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-dark"><i class="fa-solid fa-lock text-muted me-1"></i> كلمة المرور</label>
                    <input type="password" name="password" class="form-control" placeholder="اكتب كلمة المرور..." required />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-dark"><i class="fa-solid fa-user-shield text-muted me-1"></i> تسجيل الدخول كـ (الصلاحية)</label>
                    <select name="role" class="form-select" style="border-color: #ff9800; font-weight: bold;">
                        <option value="Admin">👑 مدير النظام (Admin)</option>
                        <option value="User">👤 مستخدم عادي (User)</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-login w-100 btn-lg mb-3">
                    <i class="fa-solid fa-sign-in-alt me-1"></i> دخول آمن للنظام
                </button>

                <div class="text-center">
                    <span class="text-muted small">ليس لديك حساب؟</span>
                    <a asp-action="Register" class="text-danger fw-bold small text-decoration-none ms-1">إنشاء حساب جديد</a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>