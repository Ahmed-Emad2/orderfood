@model orderfood.Models.FoodItem

@{
    ViewData["Title"] = "تعديل الوجبة";
}

<div class="container mt-4 text-right" dir="rtl" style="text-align: right;">
    <div class="card shadow border-0" style="border-radius: 12px;">
        <div class="card-header bg-warning text-dark text-center p-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
            <h2 class="fw-bold m-0"><i class="fa-solid fa-marker"></i> تعديل بيانات الوجبة</h2>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="ItemId" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="RestaurantName" class="form-label fw-bold"></label>
                        <input asp-for="RestaurantName" class="form-control" style="border-color: #ff9800;" />
                        <span asp-validation-for="RestaurantName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label fw-bold"></label>
                        <input asp-for="Name" class="form-control" style="border-color: #ff9800;" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Components" class="form-label fw-bold"></label>
                        <textarea asp-for="Components" class="form-control" rows="3" style="border-color: #ff9800;"></textarea>
                        <span asp-validation-for="Components" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Price" class="form-label fw-bold"></label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" style="border-color: #ff9800;" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Discount" class="form-label fw-bold"></label>
                        <input asp-for="Discount" class="form-control" type="number" step="0.01" style="border-color: #ff9800;" />
                        <span asp-validation-for="Discount" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <button type="submit" class="btn btn-warning fw-bold px-4 text-dark"><i class="fa-solid fa-save me-1"></i> حفظ التعديلات</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="fa-solid fa-arrow-left"></i> إلغاء والعودة</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}